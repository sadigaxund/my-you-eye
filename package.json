{
  "name": "my-you-eye",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sadigaxund/my-you-eye"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsup",
    "prebuild:lib": "node scripts/gen-manifest.mjs",
    "postbuild:lib": "node scripts/copy-styles.mjs",
    "validate": "tsc --noEmit && eslint . && node scripts/check-showcase.mjs && node scripts/check-themes.mjs && node scripts/check-contrast.mjs && npm run build:lib && vite build && node scripts/copy-styles.mjs",
    "audit": "node scripts/audit.mjs",
    "preview": "vite preview",
    "prepare": "npm run build:lib",
    "manifest": "node scripts/gen-manifest.mjs"
  },
  "files": [
    "dist",
    "bin",
    "SKILL.md",
    "components.json",
    "COMPONENTS.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "my-you-eye": "./bin/my-you-eye.mjs"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.25.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "tailwindcss": "^4.1.0",
    "tsup": "^8.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.31.0",
    "vite": "^8.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "eslint --fix --quiet --no-error-on-unmatched-pattern"
    ]
  }
}
